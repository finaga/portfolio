{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/gallery", "destination": "/gallery/index.html" },
    { "source": "/gallery/(.*)", "destination": "/gallery/index.html" },
    { "source": "/portfolio-v3", "destination": "/portfolio-v3/index.html" },
    { "source": "/portfolio-v3/(.*)", "destination": "/portfolio-v3/index.html" }
  ],
  "headers": [
    {
      "source": "/portfolio/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/gallery/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/portfolio-v3/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/portfolio-v3/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
